{
  "manifest_version": 2,
  "name": "tvbridge",
  "version": "1.0",
  "applications": {
    "gecko": {
      "id": "tvbridge@litewebtv"
    }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_start"
  }],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ]
}
